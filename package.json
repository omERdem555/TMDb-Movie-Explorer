{
  "name": "tmdb-movie-explorer",
  "version": "1.0.0",
  "description": "TMDb Movie Explorer - Full Stack Application",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "cd backend && tsc",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend",
    "start": "cd backend && npm start"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vercel/node": "^5.7.15",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
