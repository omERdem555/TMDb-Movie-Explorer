{
  "installCommand": "npm install && cd frontend && npm install",
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/movies/:path*",
      "destination": "/api/movies/:path*"
    },
    {
      "source": "/api/movies",
      "destination": "/api/movies"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}